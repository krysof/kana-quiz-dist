  "5419": "一旦开始做到底。",
  "5420": "被抓就监狱。",
  "5421": "一睡到天亮不起。",
  "5422": "他气起来没人拦。",
  "5423": "早说就好了。",
  "5424": "道歉就行却硬撑。",
  "5425": "推背说去吧。",
  "5426": "被瞪说快回。",
  "5427": "像要叫般大喊。",
  "5428": "像要哭般恳求。",
  "5429": "为圆梦努力。",
  "5430": "为活下来战斗。",
  "5431": "动辄集中力下降。",
  "5432": "他动辄感情化。",
  "5433": "完美暂不提尚可。",
  "5434": "夺冠且不说争入奖。",
  "5435": "不可相信如此荒唐。",
  "5436": "身为社会人该负责。",
  "5437": "出乎预想结果惊人。",
  "5438": "电话或邮件都行。",
  "5439": "要不要喝茶或咖啡。",
  "5440": "这工作非他不可。",
  "5441": "只经验者能懂的辛苦。",
  "5442": "多年辛苦得报的日子来了。",
  "5443": "他的行动难以理解。",
  "5444": "那人不能信赖。",
  "5445": "不论立场不该变意见。",
  "5446": "听他话说服。",
  "5447": "光这还不能安心。",
  "5448": "失败乃成功之母。",
  "5449": "父母心孩子不懂。",
  "5450": "再怎么叫都不回头。",
  "5451": "感冒不可小看。",
  "5452": "下雨比赛取消。",
  "5453": "一言状况变了。",
  "5454": "加油到最后。",
  "5455": "事已至此没办法。",
  "5456": "调查结果问题查明。",
  "5457": "按法律他无罪。",
  "5458": "身为父母守护孩子。",
  "5459": "日本人才吃米。",
  "5460": "他生气也无可厚非。",
  "5461": "听那新闻不禁流泪。",
  "5462": "熟虑后辞职。",
  "5463": "衷心祝您活跃。",
  "5464": "遗憾至极。",
  "5465": "惶恐至极。",
  "5466": "他的研究必震惊世间。",
  "5467": "儿时梦终实现。",
  "5468": "下雨下枪也去。",
  "5469": "无论什么困难都跨越。",
  "5470": "身为首相竟破法。",
  "5471": "稍微不能大意。",
  "5472": "只想休息一下。",
  "5473": "无努力无成功。",
  "5474": "礼仪是社会人该有的。",
  "5475": "这种事想都不想。",
  "5476": "他做菜美味格外。",
  "5477": "此问题之复杂难以形容。",
  "5478": "一滴水都不浪费。",
  "5479": "一秒不可松懈。",
  "5480": "盼能出一份力。",
  "5481": "一开门猫就冲进。",
  "5482": "早上起床就看报。",
  "5483": "解说过别忘。",
  "5484": "她护理母亲同时工作。",
  "5485": "吃饭的同时聊。",
  "5486": "不顾他人大吵。",
  "5487": "不顾危险冲入。",
  "5488": "冒高热出赛。",
  "5489": "哥活泼妹沉静。",
  "5490": "这菜好吃有赖他手艺和新鲜食材。",
  "5493": "如梦般接受现实。",
  "5494": "我这种人担不了那角色。",
  "5495": "作为医生不可饶恕的行为。",
  "5496": "为合格每天学习。",
  "5497": "此地禁入。",
  "5499": "事到如今无处可逃。",
  "5500": "没见到他就回国了。"
}